{%- comment -%}
  TEEORA — line icon set. Usage: {% render 'teeora-icon', name: 'gift' %}
  Thin 1.4px strokes for a refined, luxury feel.
{%- endcomment -%}
{%- liquid
  assign n = name | default: 'spark'
-%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {%- case n -%}
    {%- when 'gift' -%}
      <rect x="3" y="8" width="18" height="4"/><path d="M12 8v13M4 12v9h16v-9"/><path d="M12 8S10.5 4 8 4a2 2 0 0 0 0 4zM12 8s1.5-4 4-4a2 2 0 0 1 0 4z"/>
    {%- when 'calendar' -%}
      <rect x="3" y="4.5" width="18" height="16" rx="1"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/>
    {%- when 'spark' -%}
      <path d="M12 3l1.8 6.2L20 11l-6.2 1.8L12 19l-1.8-6.2L4 11l6.2-1.8z"/>
    {%- when 'truck' -%}
      <path d="M3 6h11v10H3zM14 9h4l3 3v4h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17.5" cy="18" r="1.6"/>
    {%- when 'leaf' -%}
      <path d="M4 20c0-8 6-14 16-14 0 10-6 16-14 16-1 0-2-.5-2-2z"/><path d="M4 20S8 14 16 10"/>
    {%- when 'heart' -%}
      <path d="M12 20S3.5 14.5 3.5 8.8A4.3 4.3 0 0 1 12 6a4.3 4.3 0 0 1 8.5 2.8C20.5 14.5 12 20 12 20z"/>
    {%- else -%}
      <circle cx="12" cy="12" r="8"/>
  {%- endcase -%}
</svg>
