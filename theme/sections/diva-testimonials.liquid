{%- comment -%}
  DIVA — Testimonials Slider
  Heading + horizontal, snap-scrolling row of review cards.
  Each review is a block, fully editable in the theme editor.
{%- endcomment -%}

{{ 'diva.css' | asset_url | stylesheet_tag }}
<script src="{{ 'diva.js' | asset_url }}" defer></script>

{%- assign s = section.settings -%}

<section
  class="diva diva-section"
  style="
    --diva-slide-cols: {{ s.slides_desktop }};
    --diva-slide-cols-tablet: {{ s.slides_tablet }};
    --diva-slide-cols-mobile: {{ s.slides_mobile }};
    --diva-gap: {{ s.gap }}px;
    --diva-pad: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
    background: {{ s.background }};
  "
>
  <div class="diva__container">
    {%- if s.heading != blank -%}<h2 class="diva-test__title diva-fade">{{ s.heading }}</h2>{%- endif -%}

    <div class="diva-hscroll diva-fade" data-diva-hscroll>
      <div class="diva-hscroll__track" data-diva-hscroll-track>
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          <figure class="diva-test-card" {{ block.shopify_attributes }}>
            <figcaption class="diva-test-card__rating">
              <span class="diva-test-card__stars" aria-hidden="true">{% for i in (1..5) %}{% if i <= b.rating %}★{% else %}☆{% endif %}{% endfor %}</span>
              <span class="visually-hidden">Rated </span>{{ b.rating }}/5
            </figcaption>
            {%- if b.product_label != blank -%}
              <a class="diva-test-card__product" href="{{ b.product_link | default: '#' }}">{{ b.product_label }}</a>
            {%- endif -%}
            {%- if b.title != blank -%}<p class="diva-test-card__heading">{{ b.title }}</p>{%- endif -%}
            {%- if b.quote != blank -%}<blockquote class="diva-test-card__quote">{{ b.quote }}</blockquote>{%- endif -%}
            {%- if b.author != blank -%}<figcaption class="diva-test-card__author">{{ b.author }}</figcaption>{%- endif -%}
          </figure>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > s.slides_desktop -%}
        <div class="diva-hscroll__arrows" style="justify-content: flex-end; margin-top: 1.25rem;">
          <button class="diva-hscroll__arrow" type="button" data-diva-hscroll-prev aria-label="Scroll left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="diva-hscroll__arrow" type="button" data-diva-hscroll-next aria-label="Scroll right">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Diva Testimonials",
  "tag": "section",
  "class": "diva-section-wrapper",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Western Wear & Cowboy Boots for Everyone" },
    { "type": "header", "content": "Cards per view" },
    { "type": "range", "id": "slides_desktop", "label": "Desktop", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "slides_tablet", "label": "Tablet", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "slides_mobile", "label": "Mobile", "min": 1, "max": 2, "step": 1, "default": 1 },
    { "type": "range", "id": "gap", "label": "Gap", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 20 },
    { "type": "header", "content": "Spacing & colour" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "color", "id": "background", "label": "Background", "default": "#faf8f3" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "product_label", "label": "Product name", "default": "The Cartwright - Scotch" },
        { "type": "url", "id": "product_link", "label": "Product link" },
        { "type": "text", "id": "title", "label": "Review title", "default": "Comfort and quality" },
        { "type": "textarea", "id": "quote", "label": "Review text", "default": "My number one concern is quality and comfort — these hit all the spots. I will absolutely purchase another pair." },
        { "type": "text", "id": "author", "label": "Author", "default": "Thad J." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Diva Testimonials",
      "category": "Diva",
      "blocks": [
        { "type": "review", "settings": { "title": "Comfort and quality", "author": "Thad J." } },
        { "type": "review", "settings": { "title": "Made for walkin!", "quote": "Bought and wore em same night — walked over 3 miles, feet felt great. A fan for life!", "author": "Michelle", "product_label": "The Sadie - Midnight" } },
        { "type": "review", "settings": { "title": "They go with everything!", "quote": "My third pair. So comfortable and they look great on. True to size.", "author": "Rena A.", "product_label": "The Daisy - Bone" } },
        { "type": "review", "settings": { "title": "Comfortable and Stylish!", "quote": "Very pleased with the comfort and versatility. I wear them with suits and with jeans.", "author": "Donnell W.", "product_label": "The Dean - Midnight" } }
      ]
    }
  ]
}
{% endschema %}
