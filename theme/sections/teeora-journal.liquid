{%- comment -%}
  TEEORA — Journal
  Latest articles from a chosen blog, editorial layout. Falls back to
  placeholders when the blog has no articles yet.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign blog = blogs[s.blog]
  assign count = s.count
-%}

<section class="tee-journal color-{{ s.color_scheme }}">
  <div class="tee-journal__head" data-tee-reveal>
    <div class="tee-journal__head-left">
      {%- if s.eyebrow != blank -%}<span class="tee-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="tee-display tee-journal__title">{{ s.heading }}</h2>{%- endif -%}
    </div>
    {%- if s.button_label != blank -%}<a class="tee-link" href="{{ s.button_link | default: blog.url | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}
  </div>

  <div class="tee-journal__grid" style="--tee-journal-cols: {{ count }};">
    {%- if blog.articles_count > 0 -%}
      {%- for article in blog.articles limit: count -%}
        <article class="tee-post" data-tee-reveal style="--tee-reveal-delay: {{ forloop.index0 | times: 90 }}ms">
          <a class="tee-post__media" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
            {%- if article.image -%}
              {{ article.image | image_url: width: 1000 | image_tag: widths: '350,600,800,1000', sizes: '(min-width:750px) 33vw, 90vw', class: 'tee-post__img', loading: 'lazy', alt: article.image.alt | default: article.title }}
            {%- else -%}{{ 'image' | placeholder_svg_tag: 'tee-post__img' }}{%- endif -%}
          </a>
          <div class="tee-post__meta">
            <span class="tee-post__tag">{{ article.tags.first | default: blog.title | default: 'Journal' }}</span>
            <a class="tee-post__title" href="{{ article.url }}">{{ article.title }}</a>
            {%- if s.show_excerpt -%}<p class="tee-post__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>{%- endif -%}
            <a class="tee-link tee-post__link" href="{{ article.url }}">Read more</a>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..count) -%}
        <article class="tee-post" data-tee-reveal>
          <div class="tee-post__media">{{ 'image' | placeholder_svg_tag: 'tee-post__img' }}</div>
          <div class="tee-post__meta">
            <span class="tee-post__tag">Journal</span>
            <span class="tee-post__title">A considered story, coming soon</span>
            {%- if s.show_excerpt -%}<p class="tee-post__excerpt">Connect a blog in the section settings to feature your latest editorial here.</p>{%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .tee-journal { background: var(--color-background); color: var(--color-foreground); padding-block: var(--tee-section-y); padding-inline: var(--tee-gutter); }
  .tee-journal__head { max-width: 1600px; margin: 0 auto clamp(2rem,4vw,3rem); display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; }
  .tee-journal__head-left { display: flex; flex-direction: column; gap: 1rem; }
  .tee-journal__title { font-size: clamp(1.8rem,3.6vw,3rem); }
  .tee-journal__grid { display: grid; grid-template-columns: repeat(var(--tee-journal-cols,3), 1fr); gap: clamp(1.5rem,3vw,2.5rem); max-width: 1600px; margin-inline: auto; }
  .tee-post__media { display: block; overflow: hidden; aspect-ratio: 4/3; background: var(--tee-cream); margin-bottom: 1.1rem; }
  .tee-post__img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.3s var(--tee-ease-luxe); }
  .tee-post:hover .tee-post__img { transform: scale(1.05); }
  .tee-post__meta { display: flex; flex-direction: column; gap: 0.7rem; align-items: flex-start; }
  .tee-post__tag { font-family: var(--tee-sans); font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; }
  .tee-post__title { font-family: var(--tee-serif); font-size: clamp(1.15rem,1.8vw,1.5rem); font-weight: 500; letter-spacing: -0.01em; line-height: 1.2; color: inherit; text-decoration: none; }
  .tee-post__title:hover { text-decoration: underline; text-underline-offset: 4px; }
  .tee-post__excerpt { font-family: var(--tee-sans); font-weight: 300; font-size: 0.92rem; line-height: 1.6; opacity: 0.78; margin: 0; }
  @media screen and (max-width: 749px) { .tee-journal__grid { grid-template-columns: 1fr; } .tee-journal__head { align-items: flex-start; } }
{% endstylesheet %}

{% schema %}
{
  "name": "TEEORA Journal",
  "tag": "section",
  "class": "tee-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Journal" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Notes from the <em>house</em>" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "count", "label": "Articles", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "text", "id": "button_label", "label": "Link label", "default": "All stories" },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [ { "name": "TEEORA Journal", "category": "TEEORA" } ]
}
{% endschema %}
