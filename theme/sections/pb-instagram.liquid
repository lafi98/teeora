{%- comment -%} PB — Instagram Gallery (13) {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<section class="pb pb-section" style="--pb-pt: {{ s.padding_top }}px; --pb-pb: {{ s.padding_bottom }}px; --pb-section-bg: {{ s.background }}; --pb-cols: {{ s.columns }}; --pb-gap: {{ s.gap }}px;">
  <div class="pb__container">
    {%- if s.heading != blank or s.handle != blank -%}
      <div class="pb-head">
        {%- if s.heading != blank -%}<h2 class="pb-title">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.handle != blank -%}<p class="pb-eyebrow">{{ s.handle }}</p>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="pb-ig__grid">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        {%- if b.link != blank -%}
          <a class="pb-ig__cell" href="{{ b.link }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="pb-ig__cell" {{ block.shopify_attributes }}>
        {%- endif -%}
          {%- if b.image != blank -%}
            {{ b.image | image_url: width: 600 | image_tag: widths: '200,300,450,600', sizes: '(min-width:750px) 16vw, 33vw', class: 'pb-ig__img', loading: 'lazy', alt: 'Gallery image' }}
          {%- else -%}
            <span class="pb-ig__img pb-noimg" role="img" aria-label="Gallery image"></span>
          {%- endif -%}
        {%- if b.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PB Instagram Gallery",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow us" },
    { "type": "text", "id": "handle", "label": "Handle", "default": "@yourbrand" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 3, "max": 8, "step": 1, "default": 6 },
    { "type": "range", "id": "gap", "label": "Gap", "min": 2, "max": 24, "step": 2, "unit": "px", "default": 10 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "PB Instagram Gallery", "blocks": [ { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" } ] }
  ]
}
{% endschema %}
