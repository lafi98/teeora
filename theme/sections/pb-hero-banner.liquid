{%- comment -%} PB — Hero Banner (1) {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign s = section.settings
  assign ov = 0
  if s.show_overlay
    assign ov = s.overlay_opacity | divided_by: 100.0
  endif
  assign desktop_class = 'pb-hero__img pb-hero__img--desktop'
  if s.mobile_image != blank
    assign desktop_class = desktop_class | append: ' pb-hero__img--has-mobile'
  endif
-%}
<section
  class="pb pb-hero"
  style="--pb-hero-h: {{ s.height }}px; --pb-hero-ov: {{ ov }}; --pb-hero-ov-color: {{ s.overlay_color }}; --pb-hero-color: {{ s.text_color }}; --pb-hero-align: {{ s.alignment }}; --pb-hero-items: {{ s.align_items }};"
>
  <div class="pb-hero__media">
    {%- if s.image != blank -%}
      {{ s.image | image_url: width: 2400 | image_tag: widths: '750,1100,1500,1900,2400', sizes: '100vw', class: desktop_class, loading: 'eager', fetchpriority: 'high', alt: s.heading | escape }}
    {%- endif -%}
    {%- if s.mobile_image != blank -%}
      {{ s.mobile_image | image_url: width: 1000 | image_tag: widths: '500,750,1000', sizes: '100vw', class: 'pb-hero__img pb-hero__img--mobile', loading: 'eager', alt: s.heading | escape }}
    {%- endif -%}
    {%- if s.show_overlay -%}<span class="pb-hero__overlay"></span>{%- endif -%}
  </div>
  <div class="pb-hero__content">
    {%- if s.eyebrow != blank -%}<p class="pb-hero__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.heading != blank -%}<h1 class="pb-hero__title">{{ s.heading }}</h1>{%- endif -%}
    {%- if s.text != blank -%}<p class="pb-hero__text">{{ s.text }}</p>{%- endif -%}
    {%- if s.button_label != blank -%}<a class="pb-btn pb-btn--light" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "PB Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (desktop)" },
    { "type": "image_picker", "id": "mobile_image", "label": "Background image (mobile)" },
    { "type": "text", "id": "eyebrow", "label": "Subtitle", "default": "New Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dresses & Jumpsuits" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "Effortless silhouettes for every occasion." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Overlay" },
    { "type": "checkbox", "id": "show_overlay", "label": "Show overlay", "default": true },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 35 },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#ffffff" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "alignment", "label": "Text alignment", "options": [ {"value":"left","label":"Left"}, {"value":"center","label":"Center"}, {"value":"right","label":"Right"} ], "default": "center" },
    { "type": "select", "id": "align_items", "label": "Content position", "options": [ {"value":"flex-start","label":"Left"}, {"value":"center","label":"Center"}, {"value":"flex-end","label":"Right"} ], "default": "center" },
    { "type": "range", "id": "height", "label": "Height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 600 }
  ],
  "presets": [ { "name": "PB Hero Banner" } ]
}
{% endschema %}
