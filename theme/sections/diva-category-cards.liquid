{%- comment -%}
  DIVA — Three Category Cards
  Block-driven image cards with an underlined label + link. Used for
  rows like Mens / Womens / Kids and Boots / Apparel / Accessories.
{%- endcomment -%}

{{ 'diva.css' | asset_url | stylesheet_tag }}
<script src="{{ 'diva.js' | asset_url }}" defer></script>

{%- assign s = section.settings -%}

<section
  class="diva diva-section"
  style="--diva-pad: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px; background: {{ s.background }};"
>
  <div class="diva__container">
    {%- if s.heading != blank -%}
      <header class="diva-head diva-fade"><h2 class="diva-head__title">{{ s.heading }}</h2></header>
    {%- endif -%}

    <div class="diva-cats3__grid diva-fade">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <a class="diva-cat3" href="{{ b.link | default: '#' }}" {{ block.shopify_attributes }}>
          <div class="diva-cat3__media">
            {%- if b.image != blank -%}
              {{ b.image | image_url: width: 900 | image_tag: widths: '300, 500, 700, 900', sizes: '(min-width: 750px) 33vw, 90vw', class: 'diva-cat3__img', loading: 'lazy', alt: b.label | escape }}
            {%- else -%}
              <span class="diva-cat3__img diva-card__noimg" role="img" aria-label="{{ b.label | escape }}"></span>
            {%- endif -%}
          </div>
          {%- if b.label != blank -%}<span class="diva-cat3__label">{{ b.label }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Diva Category Cards",
  "tag": "section",
  "class": "diva-section-wrapper",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)" },
    { "type": "header", "content": "Spacing & colour" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "color", "id": "background", "label": "Background", "default": "#faf8f3" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Diva Category Cards",
      "category": "Diva",
      "blocks": [
        { "type": "card", "settings": { "label": "Mens" } },
        { "type": "card", "settings": { "label": "Womens" } },
        { "type": "card", "settings": { "label": "Kids" } }
      ]
    }
  ]
}
{% endschema %}
