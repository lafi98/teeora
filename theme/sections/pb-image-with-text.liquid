{%- comment -%} PB — Image With Text (18) {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<section class="pb pb-section" style="--pb-pt: {{ s.padding_top }}px; --pb-pb: {{ s.padding_bottom }}px; --pb-section-bg: {{ s.background }};">
  <div class="pb__container">
    <div class="pb-iwt" data-reverse="{{ s.reverse }}" style="--pb-iwt-ratio: {{ s.image_ratio }};">
      <div class="pb-iwt__grid">
        <div class="pb-iwt__media">
          {%- if s.image != blank -%}
            {{ s.image | image_url: width: 1400 | image_tag: widths: '500,800,1100,1400', sizes: '(min-width:750px) 50vw, 100vw', class: 'pb-iwt__img', loading: 'lazy', alt: s.heading | escape }}
          {%- else -%}
            <span class="pb-iwt__img pb-noimg" role="img" aria-label="{{ s.heading | escape }}"></span>
          {%- endif -%}
        </div>
        <div class="pb-iwt__body">
          {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="pb-title">{{ s.heading }}</h2>{%- endif -%}
          {%- if s.text != blank -%}<div class="pb-iwt__text">{{ s.text }}</div>{%- endif -%}
          {%- if s.button_label != blank -%}<a class="pb-btn" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PB Image With Text",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [ {"value":"4/3","label":"Landscape"}, {"value":"1/1","label":"Square"}, {"value":"3/4","label":"Portrait"} ], "default": "4/3" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Image with text" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Pair an image with supporting copy to highlight a product, story or promise.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" }
  ],
  "presets": [ { "name": "PB Image With Text" } ]
}
{% endschema %}
