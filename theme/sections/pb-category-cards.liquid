{%- comment -%} PB — Category Cards (2) {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<section class="pb pb-section" style="--pb-pt: {{ s.padding_top }}px; --pb-pb: {{ s.padding_bottom }}px; --pb-section-bg: {{ s.background }}; --pb-cols: {{ s.columns }}; --pb-gap: {{ s.gap }}px;">
  <div class="pb__container">
    {%- if s.heading != blank -%}
      <div class="pb-head"><h2 class="pb-title">{{ s.heading }}</h2></div>
    {%- endif -%}
    <div class="pb-cards__grid">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <a class="pb-card" href="{{ b.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if b.image != blank -%}
            {{ b.image | image_url: width: 900 | image_tag: widths: '300,500,700,900', sizes: '(min-width:750px) 33vw, 90vw', class: 'pb-card__img', loading: 'lazy', alt: b.title | escape }}
          {%- else -%}
            <span class="pb-card__img pb-noimg" role="img" aria-label="{{ b.title | escape }}"></span>
          {%- endif -%}
          <span class="pb-card__scrim"></span>
          <span class="pb-card__body">
            {%- if b.title != blank -%}<span class="pb-card__title">{{ b.title }}</span>{%- endif -%}
            {%- if b.subtitle != blank -%}<span class="pb-card__sub">{{ b.subtitle }}</span>{%- endif -%}
            {%- if b.button_label != blank -%}<span class="pb-btn pb-btn--light pb-card__btn">{{ b.button_label }}</span>{%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PB Category Cards",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "gap", "label": "Gap", "min": 4, "max": 40, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Shop the edit" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "PB Category Cards", "blocks": [ { "type": "card" }, { "type": "card" }, { "type": "card" } ] }
  ]
}
{% endschema %}
