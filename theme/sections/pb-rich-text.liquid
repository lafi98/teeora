{%- comment -%} PB — Rich Text (14) — supports theme app blocks {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<section class="pb pb-section" style="--pb-pt: {{ s.padding_top }}px; --pb-pb: {{ s.padding_bottom }}px; --pb-section-bg: {{ s.background }}; --pb-align: {{ s.alignment }}; --pb-align-items: {{ s.align_items }}; --pb-rt-w: {{ s.max_width }}px;">
  <div class="pb__container">
    <div class="pb-rt">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-title">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.body != blank -%}<div class="pb-rt__body">{{ s.body }}</div>{%- endif -%}
      {%- if s.button_label != blank -%}<a class="pb-btn" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}

      {%- comment -%} Theme app block compatibility {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}{% render block %}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PB Rich Text",
  "tag": "section",
  "blocks": [ { "type": "@app" } ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rich text heading" },
    { "type": "richtext", "id": "body", "label": "Text", "default": "<p>Use this section to share your brand story, materials, or care information.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "alignment", "label": "Text alignment", "options": [ {"value":"left","label":"Left"}, {"value":"center","label":"Center"} ], "default": "center" },
    { "type": "select", "id": "align_items", "label": "Content position", "options": [ {"value":"flex-start","label":"Left"}, {"value":"center","label":"Center"} ], "default": "center" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 780 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" }
  ],
  "presets": [ { "name": "PB Rich Text" } ]
}
{% endschema %}
