{%- comment -%} PB — Call To Action Banner (20) {%- endcomment -%}
{{ 'pb.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign s = section.settings
  assign ov = 0
  if s.image != blank
    assign ov = s.overlay_opacity | divided_by: 100.0
  endif
-%}
<section class="pb pb-section pb-cta" style="--pb-pt: {{ s.padding_top }}px; --pb-pb: {{ s.padding_bottom }}px; --pb-section-bg: {{ s.background }}; --pb-cta-color: {{ s.text_color }}; --pb-promo-ov: {{ ov }};">
  {%- if s.image != blank -%}
    <div class="pb-promo__media">
      {{ s.image | image_url: width: 2400 | image_tag: widths: '750,1100,1500,2400', sizes: '100vw', class: 'pb-promo__img', loading: 'lazy', alt: s.heading | escape }}
      <span class="pb-promo__overlay"></span>
    </div>
  {%- endif -%}
  <div class="pb__container">
    <div class="pb-cta__inner">
      {%- if s.eyebrow != blank -%}<p class="pb-eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="pb-cta__title">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.text != blank -%}<p class="pb-cta__text">{{ s.text }}</p>{%- endif -%}
      {%- if s.button_label != blank -%}
        <a class="pb-btn{% if s.image != blank %} pb-btn--light{% endif %}" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PB CTA Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (optional)" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to shop the collection?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Discover dresses and jumpsuits made to move with you." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#1b1b1b" },
    { "type": "color", "id": "background", "label": "Background colour", "default": "#f6f4ef" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [ { "name": "PB CTA Banner" } ]
}
{% endschema %}
