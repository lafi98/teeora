{%- comment -%}
  TEEORA — Lookbook / Campaign
  Asymmetric editorial imagery with an offset serif statement.
  Two-image composition with gentle parallax.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
-%}

<section class="tee-look color-{{ s.color_scheme }}">
  <div class="tee-look__wrap">
    <figure class="tee-look__fig tee-look__fig--a" data-tee-reveal data-tee-parallax="-4">
      {%- if s.image_1 != blank -%}
        {{ s.image_1 | image_url: width: 1400 | image_tag: widths: '500,800,1100,1400', sizes: '(min-width:750px) 55vw, 100vw', class: 'tee-look__img', loading: 'lazy', alt: s.image_1.alt | default: '' }}
      {%- else -%}{{ 'lifestyle-1' | placeholder_svg_tag: 'tee-look__img' }}{%- endif -%}
    </figure>

    <div class="tee-look__text" data-tee-reveal style="--tee-reveal-delay:120ms">
      {%- if s.eyebrow != blank -%}<span class="tee-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="tee-display tee-look__heading">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.body != blank -%}<div class="tee-lede tee-look__lede">{{ s.body }}</div>{%- endif -%}
      {%- if s.button_label != blank -%}<a class="tee-btn tee-btn--ink tee-look__btn" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}
    </div>

    <figure class="tee-look__fig tee-look__fig--b" data-tee-reveal data-tee-parallax="5" style="--tee-reveal-delay:200ms">
      {%- if s.image_2 != blank -%}
        {{ s.image_2 | image_url: width: 900 | image_tag: widths: '350,600,900', sizes: '(min-width:750px) 32vw, 60vw', class: 'tee-look__img', loading: 'lazy', alt: s.image_2.alt | default: '' }}
      {%- else -%}{{ 'lifestyle-2' | placeholder_svg_tag: 'tee-look__img' }}{%- endif -%}
      {%- if s.caption != blank -%}<figcaption class="tee-look__cap">{{ s.caption }}</figcaption>{%- endif -%}
    </figure>
  </div>
</section>

{% stylesheet %}
  .tee-look {
    background: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--tee-section-y);
    padding-inline: var(--tee-gutter);
    overflow: hidden;
  }
  .tee-look__wrap {
    position: relative;
    max-width: 1500px; margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto auto;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .tee-look__fig { margin: 0; overflow: hidden; }
  .tee-look__fig--a { grid-column: 1 / 8; grid-row: 1 / 3; aspect-ratio: 4 / 5; }
  .tee-look__text { grid-column: 8 / 13; display: flex; flex-direction: column; align-items: flex-start; gap: 1.4rem; padding-left: clamp(0rem, 2vw, 2rem); }
  .tee-look__fig--b { grid-column: 8 / 12; aspect-ratio: 3 / 4; align-self: start; }
  .tee-look__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .tee-look__heading { font-size: clamp(2rem, 4.5vw, 3.8rem); }
  .tee-look__lede { margin: 0; }
  .tee-look__btn { margin-top: 0.5rem; }
  .tee-look__cap {
    font-family: var(--tee-sans); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase;
    opacity: 0.6; margin-top: 0.75rem;
  }
  @media screen and (max-width: 749px) {
    .tee-look__wrap { grid-template-columns: 1fr; }
    .tee-look__fig--a, .tee-look__text, .tee-look__fig--b { grid-column: 1 / -1; }
    .tee-look__fig--b { max-width: 70%; }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(max-width: 749px)').matches) return;
    var root = document.currentScript.closest('.tee-look');
    var figs = root.querySelectorAll('[data-tee-parallax]');
    var ticking = false;
    function update() {
      var vh = window.innerHeight || 1;
      figs.forEach(function (f) {
        var rect = f.getBoundingClientRect();
        var p = (rect.top + rect.height / 2 - vh / 2) / vh;
        var amt = parseFloat(f.dataset.teeParallax) || 0;
        var img = f.querySelector('.tee-look__img');
        if (img) img.style.transform = 'translate3d(0,' + (p * amt).toFixed(2) + '%,0) scale(1.06)';
      });
      ticking = false;
    }
    window.addEventListener('scroll', function () { if (!ticking) { requestAnimationFrame(update); ticking = true; } }, { passive: true });
    update();
  })();
</script>

{% schema %}
{
  "name": "TEEORA Lookbook",
  "tag": "section",
  "class": "tee-section-wrapper",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Primary image" },
    { "type": "image_picker", "id": "image_2", "label": "Secondary image" },
    { "type": "text", "id": "caption", "label": "Secondary caption", "default": "Look 07 — The Atelier Coat" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Campaign" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Light, <em>shadow</em>, form." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>A seasonal study of silhouette and texture, photographed in natural light.</p>" },
    { "type": "text", "id": "button_label", "label": "Button", "default": "View the lookbook" },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [ { "name": "TEEORA Lookbook", "category": "TEEORA" } ]
}
{% endschema %}
