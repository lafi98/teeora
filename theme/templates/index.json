        "columns": 4,
        "quick_add": true,
        "button_label": "View all",
        "button_link": "shopify://collections/all",
        "color_scheme": "scheme-1"
      }
    },
    "editorial": {
      "type": "teeora-editorial",
      "settings": {
        "flip": false,
        "index": "01",
        "eyebrow": "The House",
        "heading": "A study in <em>restraint</em>.",
        "body": "<p>We design slowly and edit ruthlessly. Every piece earns its place through material, cut and longevity — never trend.</p>",
        "button_label": "Read our story",
        "color_scheme": "scheme-2"
      }
    },
    "lookbook": {
      "type": "teeora-lookbook",
      "settings": {
        "caption": "Look 07 — The Atelier Coat",
        "eyebrow": "Campaign",
        "heading": "Light, <em>shadow</em>, form.",
        "body": "<p>A seasonal study of silhouette and texture, photographed in natural light.</p>",
        "button_label": "View the lookbook",
        "color_scheme": "scheme-1"
      }
    },
    "story": {
      "type": "teeora-story",
      "settings": {
        "eyebrow": "Our Promise",
        "heading": "Made with <em>intention</em>.",
        "body": "<p>Four principles guide everything we make.</p>",
        "color_scheme": "scheme-5"
      },
      "blocks": {
        "p1": { "type": "pillar", "settings": { "title": "Natural materials", "text": "Organic cotton, responsible wool and linen — traceable to source." } },
        "p2": { "type": "pillar", "settings": { "title": "Considered craft", "text": "Small-batch production with makers we know by name." } },
        "p3": { "type": "pillar", "settings": { "title": "Built to last", "text": "Timeless cuts and durable finishing, designed to outlive the season." } },
        "p4": { "type": "pillar", "settings": { "title": "Lighter footprint", "text": "Carbon-neutral delivery and plastic-free packaging, always." } }
      },
      "block_order": ["p1", "p2", "p3", "p4"]
    },
    "collection_best": {
      "type": "teeora-collection",
      "settings": {
        "collection": "all",
