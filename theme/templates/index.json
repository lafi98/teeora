        "button_label": "Explore the collection",
        "button_link": "shopify://collections/all",
        "button_2_label": "Discover the house",
        "text_align": "flex-start",
        "text_position": "flex-end",
        "height": 92,
        "show_scroll": true,
        "scroll_label": "Scroll",
        "color_scheme": "scheme-6"
      }
    },
    "marquee": {
      "type": "teeora-marquee",
      "settings": {
        "items": "Considered design | Natural fibres | Made to last | Complimentary shipping | Carbon-neutral delivery",
        "separator": "✦",
        "serif": false,
        "speed": 45,
        "color_scheme": "scheme-1"
      }
    },
    "collection_new": {
      "type": "teeora-collection",
      "settings": {
        "collection": "all",
        "eyebrow": "Newly Arrived",
