/*
 * DIVA collection template — a clean, fully dynamic luxury listing.
 * Assign to any collection via Products → Collections → (collection)
 * → Theme template → "diva". It renders whatever products are in the
 * collection, with a dynamic banner, sort and pagination. No hardcoded
 * or placeholder products. Header, footer and navigation are unchanged
 * (they come from the theme's section groups).
 */
{
  "sections": {
    "main": {
      "type": "diva-collection",
      "settings": {
        "show_banner": true,
        "use_collection_image": true,
        "show_description": true,
        "overlay_opacity": 35,
        "per_page": 24,
        "columns": 4,
        "columns_tablet": 3,
        "columns_mobile": 2,
        "gap": 20,
        "show_sort": true,
        "show_actions": true,
        "empty_heading": "Coming soon",
        "empty_text": "New pieces are on their way. Please check back shortly.",
        "empty_button_label": "Browse all products",
        "padding_top": 48,
        "padding_bottom": 80,
        "background": "#ffffff"
      }
    }
  },
  "order": ["main"]
}
